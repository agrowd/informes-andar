<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <title>Informe Evolutivo</title>
  <style>
    /* Estilo institucional para exportación a PDF */
    @page { size: A4; margin: 16mm; }
    :root {
      --primary: #ff7a00; /* naranja */
      --info: #5ec1ff;    /* celeste */
      --accent: #0a66c2;  /* azul */
      --text: #222;
      --muted: #666;
    }
    body { font-family: Arial, sans-serif; color: var(--text); font-size: 12px; }
    header { display: flex; align-items: center; gap: 12px; padding-bottom: 8px; border-bottom: 3px solid var(--accent); margin-bottom: 10px; }
    .brand { display:flex; align-items:center; gap:8px; }
    .brand .title { line-height: 1.2; }
    h1, h2 { margin: 0 0 8px; }
    h1 { font-size: 22px; color: var(--accent); }
    h2 { font-size: 16px; margin-top: 16px; color: var(--primary); }
    .kv { margin: 3px 0; }
    .muted { color: var(--muted); }
    .section { page-break-inside: avoid; margin-bottom: 12px; }
    .table { border-collapse: collapse; width: 100%; }
    .table th { background: rgba(10,102,194,0.08); color: #0a66c2; }
    .table th, .table td { border: 1px solid #bbb; padding: 6px; font-size: 12px; }
    .badge { display:inline-block; padding:2px 6px; background: rgba(255,122,0,0.1); color: var(--primary); border:1px solid rgba(255,122,0,0.35); border-radius:4px; font-size:10px; }
    .hero { display:flex; gap:18px; margin-bottom:16px; align-items:flex-start; }
    .hero-info { flex:1; }
    .kv-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:8px 18px; }
    .kv-grid .label { font-size:10px; text-transform:uppercase; letter-spacing:.05em; color: var(--muted); display:block; margin-bottom:2px; }
    .hero-photo { width:150px; border-radius:12px; border:1px solid #d7e3f4; overflow:hidden; background:#fff; box-shadow:0 2px 6px rgba(10,102,194,0.08); text-align:center; }
    .hero-photo img { width:100%; height:auto; display:block; }
    .hero-photo small { display:block; font-size:10px; padding:4px; color: var(--muted); }
    .circle-card { border:1px solid #dce6f5; border-radius:14px; padding:14px 18px; margin-bottom:18px; background:#f9fbff; }
    .circle-card__header { display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; }
    .circle-card__list { list-style:none; padding:0; margin:12px 0 0; display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:10px; }
    .circle-card__list li { border:1px solid #e1e8f5; border-radius:12px; padding:8px 10px; background:#fff; font-size:12px; }
    .chip { display:inline-block; padding:2px 6px; border-radius:999px; background:rgba(10,102,194,0.12); color:#0a66c2; font-size:10px; text-transform:uppercase; margin-right:6px; }
  </style>
  </head>
<body>
  <header>
    <div class="brand">
      <div class="title">
        <h1>{{ institutional.titles.mainTitle }}</h1>
        <div class="muted">Informe institucional</div>
      </div>
    </div>
    <div style="margin-left:auto; text-align:right;">
      <div class="kv"><span class="badge">Período</span> {{ report.datosGenerales.periodo }}</div>
      <div class="kv">DNI: {{ report.datosGenerales.dni or 'No informado' }}</div>
    </div>
  </header>
  <div class="hero">
    <div class="hero-info">
      <div class="kv-grid">
        <div>
          <span class="label">Nombre completo</span>
          <div>{{ report.datosGenerales.nombreCompleto }}</div>
        </div>
        <div>
          <span class="label">DNI</span>
          <div>{{ report.datosGenerales.dni or 'No informado' }}</div>
        </div>
        <div>
          <span class="label">Legajo</span>
          <div>{{ report.datosGenerales.numeroLegajo or 'No informado' }}</div>
        </div>
        <div>
          <span class="label">Obra social</span>
          <div>{{ report.datosGenerales.obraSocial or 'No informado' }}</div>
        </div>
        <div>
          <span class="label">Facilitador/a</span>
          <div>{{ report.datosGenerales.facilitadorNombre or 'No informado' }}</div>
        </div>
        {% if report.datosGenerales.metaSueño %}
        <div>
          <span class="label">Meta o sueño</span>
          <div>{{ report.datosGenerales.metaSueño }}</div>
        </div>
        {% endif %}
      </div>
    </div>
    {% if report.datosGenerales.fotoJoven %}
      <div class="hero-photo">
        <img src="{{ report.datosGenerales.fotoJoven }}" alt="Foto de {{ report.datosGenerales.nombreCompleto }}" />
        <small>Registro actualizado</small>
      </div>
    {% endif %}
  </div>

  {% if report.datosGenerales.circuloApoyoDetalle and report.datosGenerales.circuloApoyoDetalle.length %}
    <div class="circle-card">
      <div class="circle-card__header">
        <strong>{{ institutional.titles.circuloApoyo }}</strong>
        {% if report.datosGenerales.circuloApoyoParticipacion %}
          <span class="badge">{{ report.datosGenerales.circuloApoyoParticipacion }}</span>
        {% endif %}
      </div>
      <div class="kv-grid" style="margin-bottom:8px;">
        <div>
          <span class="label">Participaci?n</span>
          <div>{{ report.datosGenerales.circuloApoyoParticipacion or 'No informado' }}</div>
        </div>
        <div>
          <span class="label">Grado de involucramiento</span>
          <div>{{ report.datosGenerales.circuloApoyoInvolucramiento or 'No informado' }}</div>
        </div>
        <div>
          <span class="label">Valoraci?n grupal</span>
          <div>{{ report.datosGenerales.circuloApoyoValoracion.grupal or 'No informado' }}</div>
        </div>
        <div>
          <span class="label">Valoraci?n individual</span>
          <div>{{ report.datosGenerales.circuloApoyoValoracion.individual or 'No informado' }}</div>
        </div>
      </div>
      <ul class="circle-card__list">
        {% for miembro in report.datosGenerales.circuloApoyoDetalle %}
          <li><span class="chip">{{ miembro.vinculo }}</span> {{ miembro.nombre }}</li>
        {% endfor %}
      </ul>
    </div>
  {% else %}
    <div class="kv">C?rculo de Apoyo: {{ report.datosGenerales.circuloApoyo | join(', ') }}</div>
  {% endif %}

  {% macro renderSection(title, items) %}
    <div class="section">
      <h2>{{ title }}</h2>
      {% if items and items.length > 0 %}
        <ul>
          {% for it in items %}
            <li>{{ it.texto }}</li>
          {% endfor %}
        </ul>
      {% else %}
        <p class="muted">No informado</p>
      {% endif %}
    </div>
  {% endmacro %}

  {{ renderSection(institutional.titles.objetivo, report.secciones.objetivo) }}
  {{ renderSection(institutional.titles.escucha, report.secciones.escucha) }}
  {{ renderSection('Abordaje del período', report.secciones.abordaje) }}
  {{ renderSection(institutional.titles.estadoEmocional, report.secciones.estadoEmocional) }}
  {{ renderSection(institutional.titles.apoyosAjustes, report.secciones.apoyosAjustes) }}

  <div class="section">
    <h2>{{ institutional.titles.evaluacion }}</h2>
    <table class="table">
      <thead>
        <tr>
          <th>Dimensión</th>
          <th>Evolución</th>
          <th>Comentario</th>
        </tr>
      </thead>
      <tbody>
        {% for dim in report.evaluacionDimensiones %}
        <tr>
          <td>{{ dim.dimension }}</td>
          <td>{{ dim.evolucion }}</td>
          <td>{{ dim.comentario or '' }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  {{ renderSection(institutional.titles.logros, report.secciones.logros) }}
  {{ renderSection(institutional.titles.suenosMetas, report.secciones.suenosMetas) }}
  {{ renderSection(institutional.titles.circuloApoyo, report.secciones.circuloApoyo) }}
  {{ renderSection(institutional.titles.sugerencias, report.secciones.sugerencias) }}

</body>
</html>

