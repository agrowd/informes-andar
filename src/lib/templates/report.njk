<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <title>Informe Evolutivo</title>
  <style>
    @page { 
      size: A4; 
      margin-top: 52mm; 
      margin-bottom: 25.4mm; 
      margin-left: 25.4mm; 
      margin-right: 25.4mm; 
    }
    
    body { 
      font-family: 'Georgia', 'Times New Roman', serif; 
      color: #000; 
      font-size: 11.5pt; 
      line-height: 1.6; 
      margin: 0; 
      padding: 0;
    }
    
    .header { 
      text-align: center; 
      margin-bottom: 24pt; 
      margin-top: 10pt;
    }
    .header h1 { 
      font-size: 13.5pt; 
      font-weight: bold; 
      margin: 0 0 6pt; 
      text-transform: uppercase; 
      color: #000; 
      line-height: 1.3;
    }
    .header .subtitle { 
      font-size: 10.5pt; 
      font-style: italic; 
      color: #444; 
      margin: 0; 
    }
    
    h2 { 
      font-size: 11.5pt; 
      font-weight: bold; 
      margin: 22pt 0 8pt; 
      text-transform: uppercase; 
      color: #000; 
    }
    
    p { 
      margin: 0 0 10pt; 
      text-align: justify; 
      text-indent: 0;
    }
    
    .datos-generales { 
      margin-bottom: 16pt; 
    }
    .datos-generales-row { 
      margin-bottom: 6pt; 
    }
    .datos-generales-label { 
      font-weight: bold; 
    }
    
    .table { 
      border-collapse: collapse; 
      width: 100%; 
      margin: 15pt 0; 
    }
    .table th, .table td { 
      border: 1px solid #000; 
      padding: 8px 10px; 
      font-size: 11pt; 
      text-align: left; 
      vertical-align: top; 
      line-height: 1.4;
    }
    .table th { 
      font-weight: bold; 
      background-color: #f2f2f2; 
    }
    
    .sub-section-title { 
      font-weight: bold; 
      margin-top: 14pt; 
      margin-bottom: 4pt; 
      font-size: 11.5pt; 
    }
    
    .section { 
      page-break-inside: avoid; 
    }
    
    ul {
      margin: 0 0 10pt;
      padding-left: 20pt;
    }
    li {
      margin-bottom: 6pt;
      text-align: justify;
    }
  </style>
</head>
<body>

  <div class="header">

    <h1>{{ institutional.titles.mainTitle }}</h1>
    <p class="subtitle">(Modelo Social de la Discapacidad – Calidad de Vida – Planificación Centrada en la Persona)</p>
  </div>

  <div class="section">
    <h2>1. DATOS GENERALES</h2>
    <div class="datos-generales">
      <div class="datos-generales-row"><span class="datos-generales-label">Nombre completo:</span> {{ report.datosGenerales.nombreCompleto }}</div>
      <div class="datos-generales-row"><span class="datos-generales-label">DNI:</span> {{ report.datosGenerales.dni or 'No informado' }}</div>
      {% if report.datosGenerales.numeroLegajo %}
      <div class="datos-generales-row"><span class="datos-generales-label">Número de legajo:</span> {{ report.datosGenerales.numeroLegajo }}</div>
      {% endif %}
      {% if report.datosGenerales.youngId %}
      <div class="datos-generales-row"><span class="datos-generales-label">ID del Joven:</span> {{ report.datosGenerales.youngId }}</div>
      {% endif %}
      <div class="datos-generales-row"><span class="datos-generales-label">Facilitador/a:</span> {{ report.datosGenerales.facilitadorNombre or 'No informado' }}</div>
      <div class="datos-generales-row"><span class="datos-generales-label">Período evaluado:</span> {{ report.datosGenerales.periodo }}</div>
      <div class="datos-generales-row"><span class="datos-generales-label">ID del Informe / Borrador:</span> {{ report.id or report._id or 'Borrador' }}</div>
      <div class="datos-generales-row"><span class="datos-generales-label">Sueño de la persona:</span> {{ report.datosGenerales.metaSueño or 'No informado' }}</div>
      <div class="datos-generales-row">
        <span class="datos-generales-label">Participación del círculo de apoyo (Sí/No):</span> 
        {{ report.datosGenerales.circuloApoyoParticipacion or 'No informado' }}
      </div>
      <div class="datos-generales-row">
        <span class="datos-generales-label">Personas que lo integran:</span> 
        {% if report.datosGenerales.circuloApoyoDetalle and report.datosGenerales.circuloApoyoDetalle.length %}
          {% set nombres = [] %}
          {% for miembro in report.datosGenerales.circuloApoyoDetalle %}
            {% set v = miembro.vinculo | default('') %}
            {% set n = miembro.nombre | default('') %}
            {% set label = n + ' (' + v + ')' if v else n %}
            {% set nombres = (nombres.push(label), nombres) %}
          {% endfor %}
          {{ nombres | join(', ') }}
        {% elif report.datosGenerales.circuloApoyo and report.datosGenerales.circuloApoyo.length %}
          {{ report.datosGenerales.circuloApoyo | join(', ') }}
        {% else %}
          No informado
        {% endif %}
      </div>
    </div>
  </div>

  {% macro renderNarrativeSection(title, items) %}
    <div class="section">
      <h2>{{ title }}</h2>
      {% if items and items.length > 0 %}
        {% for it in items %}
          <p>{{ it.texto }}</p>
        {% endfor %}
      {% else %}
        <p style="color: #666; font-style: italic;">No informado</p>
      {% endif %}
    </div>
  {% endmacro %}

  {{ renderNarrativeSection(institutional.titles.objetivo, report.secciones.objetivo) }}
  {{ renderNarrativeSection(institutional.titles.escucha, report.secciones.escucha) }}
  {{ renderNarrativeSection(institutional.titles.estadoEmocional, report.secciones.estadoEmocional) }}
  {{ renderNarrativeSection(institutional.titles.apoyosAjustes, report.secciones.apoyosAjustes) }}

  <div class="section">
    <h2>{{ institutional.titles.evaluacion }}</h2>
    <p style="font-style: italic; margin-bottom: 8pt;">Usar escala: ✔ Mejoró / ➖ Mantuvo / ❌ Dificultad</p>
    <table class="table">
      <thead>
        <tr>
          <th style="width: 25%;">Dimensión</th>
          <th style="width: 15%; text-align: center;">Valoración</th>
          <th style="width: 60%;">Comentario breve</th>
        </tr>
      </thead>
      <tbody>
        {% for dim in report.evaluacionDimensiones %}
        <tr>
          <td>{{ dim.dimension }}</td>
          <td style="text-align: center;">{{ dim.evolucion }}</td>
          <td>{{ dim.comentario or '' }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <div class="section">
    <h2>{{ institutional.titles.logros }}</h2>
    {% if report.secciones.logros and report.secciones.logros.length > 0 %}
      {% set practicas = [] %}
      {% set emocionales = [] %}
      {% set decisiones = [] %}
      {% set experiencias = [] %}

      {% for it in report.secciones.logros %}
        {% set t = it.texto | lower %}
        {% if 'autónom' in t or 'manipular' in t or 'sujetar' in t or 'hidratar' in t or 'independencia' in t or 'cuchara' in t or 'vaso' in t or 'funcional' in t or 'práctica' in t %}
          {% set practicas = (practicas.push(it.texto), practicas) %}
        {% elif 'emocional' in t or 'tolerancia' in t or 'regulación' in t or 'social' in t or 'vínculo' in t or 'relación' in t or 'convivencia' in t %}
          {% set emocionales = (emocionales.push(it.texto), emocionales) %}
        {% elif 'preferencia' in t or 'elección' in t or 'decisión' in t or 'manifestar' in t or 'expresar' in t %}
          {% set decisiones = (decisiones.push(it.texto), decisiones) %}
        {% elif 'salida' in t or 'evento' in t or 'experiencia' in t or 'participó' in t or 'disfrute' in t or 'boliche' in t or 'taller' in t or 'actividad' in t %}
          {% set experiencias = (experiencias.push(it.texto), experiencias) %}
        {% else %}
          {% set practicas = (practicas.push(it.texto), practicas) %}
        {% endif %}
      {% endfor %}

      {% if practicas.length > 0 %}
        <div class="sub-section-title">Habilidades prácticas o funcionales</div>
        <p>{{ practicas | join(' ') }}</p>
      {% endif %}

      {% if emocionales.length > 0 %}
        <div class="sub-section-title">Habilidades emocionales y sociales</div>
        <p>{{ emocionales | join(' ') }}</p>
      {% endif %}

      {% if decisiones.length > 0 %}
        <div class="sub-section-title">Participación en decisiones</div>
        <p>{{ decisiones | join(' ') }}</p>
      {% endif %}

      {% if experiencias.length > 0 %}
        <div class="sub-section-title">Nuevas experiencias u oportunidades aprovechadas</div>
        <p>{{ experiencias | join(' ') }}</p>
      {% endif %}
    {% else %}
      <p style="color: #666; font-style: italic;">No informado</p>
    {% endif %}
  </div>

  {{ renderNarrativeSection(institutional.titles.suenosMetas, report.secciones.suenosMetas) }}
  {{ renderNarrativeSection(institutional.titles.circuloApoyo, report.secciones.circuloApoyo) }}

  <div class="section">
    <h2>{{ institutional.titles.sugerencias }}</h2>
    {% if report.secciones.sugerencias and report.secciones.sugerencias.length > 0 %}
      <ul>
        {% for it in report.secciones.sugerencias %}
          <li>{{ it.texto }}</li>
        {% endfor %}
      </ul>
    {% else %}
      <p style="color: #666; font-style: italic;">No informado</p>
    {% endif %}
  </div>

</body>
</html>
